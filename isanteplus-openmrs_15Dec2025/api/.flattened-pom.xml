    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>org.openmrs.module</groupId>
    <artifactId>isanteplus</artifactId>
    <version>1.3.0</version>
  </parent>
  <groupId>org.openmrs.module</groupId>
